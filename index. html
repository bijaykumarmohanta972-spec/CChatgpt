<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Universal AI - Gemini Clone</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; }

        /* Mobile safe height utility */
        .safe-height { height: calc(100vh - env(safe-area-inset-bottom)); }
        
        /* Markdown Styling */
        .prose pre { background: #1e293b; color: #f8fafc; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 0.5rem 0; }
        .prose code { font-family: monospace; font-size: 0.9em; background: rgba(0,0,0,0.1); padding: 0.2rem 0.4rem; border-radius: 0.25rem; }
        .dark .prose code { background: rgba(255,255,255,0.1); }
        .prose p { margin-bottom: 0.75rem; }

        /* Animation */
        .fade-in { animation: fadeIn 0.3s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

        #app-content { display: none; }
        #loading { display: flex; align-items: center; justify-content: center; height: 100vh; font-family: sans-serif; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-zinc-900 text-slate-900 dark:text-zinc-100 transition-colors duration-200">

    <div id="loading">
        <div class="flex flex-col items-center">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mb-4"></div>
            <p class="text-slate-500">Initializing Gemini AI...</p>
        </div>
    </div>

    <div id="app-content" class="flex h-screen overflow-hidden">
        
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-20 hidden lg:hidden" onclick="toggleSidebar()"></div>

        <aside id="sidebar" class="fixed lg:relative inset-y-0 left-0 w-72 bg-white dark:bg-zinc-950 border-r border-slate-200 dark:border-zinc-800 z-30 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 flex flex-col">
            <div class="p-4 flex flex-col h-full">
                <button onclick="createNewChat()" class="flex items-center gap-3 w-full p-3 bg-slate-100 dark:bg-zinc-800 hover:bg-slate-200 dark:hover:bg-zinc-700 rounded-full transition-all mb-6">
                    <i class="fa-solid fa-plus ml-1"></i>
                    <span class="font-medium">New Chat</span>
                </button>

                <div class="flex-1 overflow-y-auto space-y-2 mb-4" id="chat-history-list">
                    </div>

                <div class="border-t border-slate-200 dark:border-zinc-800 pt-4 space-y-2">
                    <button onclick="openSettings()" class="flex items-center gap-3 w-full p-2 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-lg transition-all">
                        <i class="fa-solid fa-gear w-5"></i>
                        <span>Settings</span>
                    </button>
                    <button onclick="toggleDarkMode()" class="flex items-center gap-3 w-full p-2 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-lg transition-all">
                        <i id="theme-icon" class="fa-solid fa-moon w-5"></i>
                        <span id="theme-text">Dark Mode</span>
                    </button>
                </div>
            </div>
        </aside>

        <main class="flex-1 flex flex-col relative w-full h-full overflow-hidden">
            
            <header class="flex items-center justify-between p-4 border-b border-slate-200 dark:border-zinc-800 bg-white/80 dark:bg-zinc-900/80 backdrop-blur-md z-10">
                <div class="flex items-center gap-3">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-slate-100 dark:hover:bg-zinc-800 rounded-lg">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <h2 id="current-chat-title" class="font-semibold truncate max-w-[150px] md:max-w-md">New Conversation</h2>
                </div>
                <div class="flex items-center gap-2">
                    <span id="model-badge" class="text-[10px] px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-md font-mono uppercase"></span>
                </div>
            </header>

            <div id="messages-container" class="flex-1 overflow-y-auto p-4 md:p-8 space-y-6 scroll-smooth">
                <div id="welcome-view" class="h-full flex flex-col items-center justify-center text-center space-y-4">
                    <div class="text-4xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">Hello! How can I help?</div>
                    <p class="text-slate-500 max-w-sm">Start a conversation or ask a question to begin.</p>
                </div>
            </div>

            <div class="p-4 md:p-6 bg-gradient-to-t from-white dark:from-zinc-900 via-white dark:via-zinc-900 to-transparent">
                <div class="max-w-4xl mx-auto relative">
                    <div class="flex items-end gap-2 bg-white dark:bg-zinc-800 border border-slate-300 dark:border-zinc-700 rounded-2xl shadow-sm focus-within:ring-2 ring-blue-500/20 p-2 transition-all">
                        <textarea id="chat-input" rows="1" placeholder="Type a message..." 
                            class="flex-1 bg-transparent border-none focus:ring-0 resize-none p-2 max-h-48 min-h-[44px]"
                            oninput="autoResize(this)"></textarea>
                        <button id="send-btn" onclick="handleSend()" class="p-2 w-10 h-10 bg-blue-600 hover:bg-blue-700 disabled:bg-slate-300 text-white rounded-xl transition-all flex items-center justify-center">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </div>
                    <p class="text-[10px] text-center mt-2 text-slate-400">Universal AI can make mistakes. Verify important info.</p>
                </div>
            </div>
        </main>
    </div>

    <div id="settings-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div class="bg-white dark:bg-zinc-900 w-full max-w-md rounded-2xl shadow-2xl overflow-hidden border border-slate-200 dark:border-zinc-800">
            <div class="p-6 space-y-4">
                <div class="flex justify-between items-center border-b border-slate-100 dark:border-zinc-800 pb-4">
                    <h3 class="text-xl font-bold">Settings</h3>
                    <button onclick="closeSettings()" class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark"></i></button>
                </div>
                
                <div class="space-y-4 pt-2">
                    <div>
                        <label class="block text-sm font-medium mb-1">OpenRouter API Key</label>
                        <input type="password" id="api-key-input" class="w-full p-2 rounded-lg border dark:bg-zinc-800 dark:border-zinc-700" placeholder="sk-or-v1-...">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Model Name</label>
                        <input type="text" id="model-input" class="w-full p-2 rounded-lg border dark:bg-zinc-800 dark:border-zinc-700" placeholder="deepseek/deepseek-r1:free">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">System Prompt</label>
                        <textarea id="system-prompt-input" rows="3" class="w-full p-2 rounded-lg border dark:bg-zinc-800 dark:border-zinc-700 text-sm" placeholder="You are a helpful AI assistant..."></textarea>
                    </div>
                </div>

                <div class="flex gap-3 pt-4">
                    <button onclick="saveSettings()" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700 transition-all">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- State Management ---
        let state = {
            apiKey: localStorage.getItem('api_key') || '',
            model: localStorage.getItem('model') || 'deepseek/deepseek-r1:free',
            systemPrompt: localStorage.getItem('system_prompt') || 'You are a helpful, concise AI assistant.',
            chats: JSON.parse(localStorage.getItem('chats')) || [],
            currentChatId: null,
            isStreaming: false,
            isDark: localStorage.getItem('theme') === 'dark'
        };

        // --- DOM Elements ---
        const els = {
            loading: document.getElementById('loading'),
            app: document.getElementById('app-content'),
            msgContainer: document.getElementById('messages-container'),
            input: document.getElementById('chat-input'),
            historyList: document.getElementById('chat-history-list'),
            settingsModal: document.getElementById('settings-modal'),
            welcome: document.getElementById('welcome-view'),
            chatTitle: document.getElementById('current-chat-title'),
            modelBadge: document.getElementById('model-badge'),
            sendBtn: document.getElementById('send-btn')
        };

        // --- Initialization ---
        window.addEventListener('DOMContentLoaded', () => {
            initTheme();
            renderHistory();
            updateModelBadge();
            
            // Hide loader
            els.loading.style.display = 'none';
            els.app.style.display = 'flex';

            // Key listener
            els.input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    handleSend();
                }
            });

            if (!state.apiKey) openSettings();
        });

        // --- Core Functions ---

        function initTheme() {
            if (state.isDark) {
                document.documentElement.classList.add('dark');
                document.getElementById('theme-icon').className = 'fa-solid fa-sun w-5';
                document.getElementById('theme-text').innerText = 'Light Mode';
            }
        }

        function toggleDarkMode() {
            state.isDark = !state.isDark;
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', state.isDark ? 'dark' : 'light');
            initTheme();
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const isOpen = sidebar.classList.contains('translate-x-0');
            
            if (isOpen) {
                sidebar.classList.add('-translate-x-full');
                sidebar.classList.remove('translate-x-0');
                overlay.classList.add('hidden');
            } else {
                sidebar.classList.remove('-translate-x-full');
                sidebar.classList.add('translate-x-0');
                overlay.classList.remove('hidden');
            }
        }

        function autoResize(textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = Math.min(textarea.scrollHeight, 192) + 'px';
        }

        // --- Chat Logic ---

        function createNewChat() {
            const newChat = {
                id: Date.now().toString(),
                title: 'New Conversation',
                messages: [],
                systemPrompt: state.systemPrompt
            };
            state.chats.unshift(newChat);
            state.currentChatId = newChat.id;
            saveChats();
            renderHistory();
            renderMessages();
            if (window.innerWidth < 1024) toggleSidebar();
        }

        function switchChat(id) {
            state.currentChatId = id;
            renderMessages();
            if (window.innerWidth < 1024) toggleSidebar();
        }

        function deleteChat(id, event) {
            event.stopPropagation();
            state.chats = state.chats.filter(c => c.id !== id);
            if (state.currentChatId === id) state.currentChatId = null;
            saveChats();
            renderHistory();
            renderMessages();
        }

        async function handleSend() {
            const text = els.input.value.trim();
            if (!text || state.isStreaming) return;
            if (!state.apiKey) return openSettings();

            // Setup chat if none active
            if (!state.currentChatId) {
                const newChat = { id: Date.now().toString(), title: text.substring(0, 30), messages: [], systemPrompt: state.systemPrompt };
                state.chats.unshift(newChat);
                state.currentChatId = newChat.id;
            }

            const currentChat = state.chats.find(c => c.id === state.currentChatId);
            
            // Add User Message
            currentChat.messages.push({ role: 'user', content: text });
            if (currentChat.title === 'New Conversation') currentChat.title = text.substring(0, 30);
            
            els.input.value = '';
            els.input.style.height = 'auto';
            renderMessages();
            renderHistory();

            // Prepare AI message placeholder
            const aiMsgIndex = currentChat.messages.length;
            currentChat.messages.push({ role: 'assistant', content: '' });
            
            state.isStreaming = true;
            els.sendBtn.disabled = true;

            try {
                const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                    method: "POST",
                    headers: {
                        "Authorization": `Bearer ${state.apiKey}`,
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        model: state.model,
                        messages: [
                            { role: "system", content: currentChat.systemPrompt },
                            ...currentChat.messages.slice(0, -1)
                        ],
                        stream: true
                    })
                });

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let accumulatedContent = "";

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n').filter(line => line.trim() !== '');

                    for (const line of lines) {
                        const message = line.replace(/^data: /, '');
                        if (message === '[DONE]') break;
                        
                        try {
                            const parsed = JSON.parse(message);
                            const content = parsed.choices[0].delta.content || '';
                            accumulatedContent += content;
                            
                            // Update UI in real-time
                            currentChat.messages[aiMsgIndex].content = accumulatedContent;
                            updateLastAIMessage(accumulatedContent);
                        } catch (e) {}
                    }
                }
            } catch (error) {
                currentChat.messages[aiMsgIndex].content = "⚠️ Error: " + error.message;
                renderMessages();
            } finally {
                state.isStreaming = false;
                els.sendBtn.disabled = false;
                saveChats();
            }
        }

        // --- UI Rendering ---

        function renderHistory() {
            els.historyList.innerHTML = state.chats.map(chat => `
                <div onclick="switchChat('${chat.id}')" class="group flex items-center justify-between p-3 rounded-xl cursor-pointer transition-all ${state.currentChatId === chat.id ? 'bg-blue-50 dark:bg-blue-900/20 text-blue-600' : 'hover:bg-slate-100 dark:hover:bg-zinc-900'}">
                    <div class="flex items-center gap-3 overflow-hidden">
                        <i class="fa-regular fa-message text-sm"></i>
                        <span class="truncate text-sm font-medium">${chat.title}</span>
                    </div>
                    <button onclick="deleteChat('${chat.id}', event)" class="opacity-0 group-hover:opacity-100 p-1 hover:text-red-500 transition-all">
                        <i class="fa-solid fa-trash-can text-xs"></i>
                    </button>
                </div>
            `).join('');
        }

        function renderMessages() {
            const chat = state.chats.find(c => c.id === state.currentChatId);
            
            if (!chat || chat.messages.length === 0) {
                els.welcome.classList.remove('hidden');
                els.msgContainer.innerHTML = '';
                els.msgContainer.appendChild(els.welcome);
                els.chatTitle.innerText = "New Conversation";
                return;
            }

            els.welcome.classList.add('hidden');
            els.chatTitle.innerText = chat.title;

            els.msgContainer.innerHTML = chat.messages.map((m, idx) => `
                <div class="flex ${m.role === 'user' ? 'justify-end' : 'justify-start'} fade-in">
                    <div class="max-w-[85%] md:max-w-[70%] flex gap-3 ${m.role === 'user' ? 'flex-row-reverse' : ''}">
                        <div class="w-8 h-8 rounded-full flex-shrink-0 flex items-center justify-center text-xs ${m.role === 'user' ? 'bg-blue-600 text-white' : 'bg-emerald-600 text-white'}">
                            ${m.role === 'user' ? 'U' : 'AI'}
                        </div>
                        <div class="p-4 rounded-2xl prose dark:prose-invert max-w-none ${m.role === 'user' ? 'bg-blue-600 text-white prose-p:text-white' : 'bg-white dark:bg-zinc-800 border border-slate-200 dark:border-zinc-700 shadow-sm'}">
                            <div id="msg-${idx}">${marked.parse(m.content)}</div>
                        </div>
                    </div>
                </div>
            `).join('');
            
            els.msgContainer.scrollTop = els.msgContainer.scrollHeight;
        }

        function updateLastAIMessage(content) {
            const chat = state.chats.find(c => c.id === state.currentChatId);
            const lastIdx = chat.messages.length - 1;
            const element = document.getElementById(`msg-${lastIdx}`);
            if (element) {
                element.innerHTML = marked.parse(content);
                els.msgContainer.scrollTop = els.msgContainer.scrollHeight;
            }
        }

        // --- Settings ---

        function openSettings() {
            document.getElementById('api-key-input').value = state.apiKey;
            document.getElementById('model-input').value = state.model;
            document.getElementById('system-prompt-input').value = state.systemPrompt;
            els.settingsModal.classList.remove('hidden');
        }

        function closeSettings() {
            els.settingsModal.classList.add('hidden');
        }

        function saveSettings() {
            state.apiKey = document.getElementById('api-key-input').value.trim();
            state.model = document.getElementById('model-input').value.trim() || 'deepseek/deepseek-r1:free';
            state.systemPrompt = document.getElementById('system-prompt-input').value.trim();
            
            localStorage.setItem('api_key', state.apiKey);
            localStorage.setItem('model', state.model);
            localStorage.setItem('system_prompt', state.systemPrompt);
            
            updateModelBadge();
            closeSettings();
        }

        function saveChats() {
            localStorage.setItem('chats', JSON.stringify(state.chats.slice(0, 20))); // Keep last 20 for storage limits
        }

        function updateModelBadge() {
            els.modelBadge.innerText = state.model.split('/').pop();
        }

    </script>
</body>
</html>
